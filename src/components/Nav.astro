<div id="main-content"></div>

<script>
	const openMenu = () => {
		document.querySelectorAll('.navbar-menu').forEach((m) => m.classList.remove('hidden'));
	};

	const closeMenu = () => {
		document.querySelectorAll('.navbar-menu').forEach((m) => m.classList.add('hidden'));
	};

	document.querySelector('.navbar-burger')?.addEventListener('click', openMenu);
	document.querySelector('.navbar-close')?.addEventListener('click', closeMenu);
	document.querySelector('[data-close-menu]')?.addEventListener('click', closeMenu);
</script>
